# ============================================================================
# TracePilot environment configuration
# Copy to `.env` (root) for docker-compose, and to apps/api/.env for local runs.
# ============================================================================

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
LOG_JSON=false

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Storage / metadata ---
DATA_DIR=./.tracepilot
WORKSPACES_DIR=./.tracepilot/workspaces
DATABASE_URL=sqlite:///./.tracepilot/tracepilot.db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tracepilot_chunks

# --- Ollama (model serving) ---
# To use Ollama running on your host machine instead of the container, set:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_GEN_MODEL=llama3.1:8b
OLLAMA_REASONING_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
MODEL_TEMPERATURE=0.1
MODEL_NUM_CTX=8192
REQUEST_TIMEOUT_SECONDS=120

# --- Embeddings ---
# fastembed runs locally in-process (no model pull needed). Switch to `ollama`
# to use OLLAMA_EMBED_MODEL (remember to set EMBEDDING_DIM=768 for nomic-embed-text).
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Langfuse (observability + evals) ---
# These keys match the LANGFUSE_INIT_* values seeded in docker-compose.yml.
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://langfuse-server:3000
LANGFUSE_PUBLIC_KEY=pk-lf-tracepilot-public
LANGFUSE_SECRET_KEY=sk-lf-tracepilot-secret

# --- Retrieval ---
RETRIEVAL_TOP_K=8
HYBRID_ALPHA=0.6
RERANK_ENABLED=false
MAX_CONTEXT_CHARS=16000

# --- Tooling sandbox ---
TOOL_TIMEOUT_SECONDS=30
TOOL_MAX_OUTPUT_BYTES=64000
TOOL_ALLOWLIST=

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
